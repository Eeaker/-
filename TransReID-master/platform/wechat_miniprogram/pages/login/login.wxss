.login-container {
  display: flex;
  justify-content: center;
  align-items: center;
  background: radial-gradient(circle at center, var(--bg-overlay) 0%, var(--bg-base) 100%);
}

.login-box {
  width: 100%;
  max-width: 600rpx;
  background: var(--bg-overlay-glass);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 60rpx 40rpx;
  box-shadow: var(--shadow-soft);
}

.logo-area {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-title {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--text-main);
  letter-spacing: -1rpx;
}

.highlight {
  color: var(--primary-color);
}

.logo-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

.mode-tabs {
  display: flex;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-bottom: 30rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  color: var(--text-secondary);
  background: rgba(0, 0, 0, 0.18);
  font-size: 26rpx;
}

.mode-tab.active {
  color: #fff;
  background: var(--primary-color);
}

.input-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.custom-input {
  width: 100%;
  height: 88rpx;
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  color: var(--text-main);
  font-size: 28rpx;
  box-sizing: border-box;
}

.placeholder-style {
  color: #555;
}

.premium-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 50rpx;
  font-size: 32rpx;
}

.default-tip {
  display: block;
  text-align: center;
  margin-top: 24rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}
