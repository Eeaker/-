/* video_player.wxss */

/* 
  .player-page 必须不设置任何 position，否则 WeChat 原生视频全屏失效
  使用普通 block 流布局
*/
.player-page {
  min-height: 100vh;
  background: #000;
}

/* 视频：无 border-radius，无 position，直接撑满宽度 */
.main-video {
  width: 100%;
  height: 480rpx;
  display: block;
  background: #000;
}

/* 片段跳转栏 */
.segments-bar {
  background: #15161C;
  padding: 24rpx 30rpx;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.bar-title {
  display: block;
  font-size: 24rpx;
  color: #8B8E98;
  margin-bottom: 16rpx;
}

.chips-row {
  white-space: nowrap;
  height: 100rpx;
}

.chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(232, 99, 33, 0.15);
  border: 1px solid rgba(232, 99, 33, 0.35);
  border-radius: 16rpx;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  transition: background 0.15s;
}

.chip:active {
  background: rgba(232, 99, 33, 0.4);
}

.chip-time {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF8F54;
}

.chip-score {
  font-size: 20rpx;
  color: #8B8E98;
  margin-top: 4rpx;
}

/* 任务信息 */
.info-bar {
  padding: 20rpx 30rpx;
  background: #15161C;
}

.info-text {
  font-size: 22rpx;
  color: #8B8E98;
}

/* 加载/错误居中 */
.center-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 20rpx;
}

.state-icon {
  font-size: 80rpx;
}

.state-text {
  font-size: 28rpx;
  color: #8B8E98;
}
