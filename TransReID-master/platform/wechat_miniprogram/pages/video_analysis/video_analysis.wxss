.video-container {
  padding-bottom: 50rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }

.section-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.upload-box {
  width: 100%;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-md);
  background: rgba(0,0,0,0.2);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  margin-bottom: 30rpx;
}

.small-box {
  height: 280rpx;
}

.upload-icon {
  font-size: 60rpx;
  font-weight: 300;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.preview-img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: contain;
}

.preview-video {
  width: 100%;
  height: 100%;
  display: block;
}

.reselect-overlay {
  position: absolute;
  top: 0;
  width: 100%;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 12rpx 0;
  z-index: 10;
}

/* Progress / Terminal Style */
.progress-box {
  margin: 60rpx 0;
}

.progress-track {
  height: 12rpx;
  background: #23262F;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  transition: width 0.3s ease-out;
}

.progress-text {
  font-size: 28rpx;
  color: var(--primary-light);
  font-weight: bold;
}

.status-log {
  background: #000;
  padding: 24rpx;
  border-radius: var(--radius-sm);
  border: 1px solid #333;
}

.log-text {
  display: block;
  font-family: monospace;
  font-size: 22rpx;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.blink {
  animation: blink 1s infinite alternate;
}
@keyframes blink {
  0% { opacity: 1; }
  100% { opacity: 0.5; }
}

/* Result Video */
.result-video {
  width: 100%;
  height: 420rpx;
  display: block;
  margin-bottom: 20rpx;
  background: #000;
}

.matches-list {
  max-height: 500rpx;
}

.match-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.05);
  padding: 20rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
  transition: background 0.2s;
}

.match-item:active {
  background: rgba(255,255,255,0.1);
}

.time-badge {
  background: var(--primary-color);
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  margin-right: 24rpx;
}

.match-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.match-desc {
  font-size: 26rpx;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.match-score {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.crop-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
  border: 1px solid var(--border-color);
}

.empty-matches {
  text-align: center;
  color: var(--text-secondary);
  font-size: 26rpx;
  padding: 40rpx 0;
}

.cancel-btn {
  margin-top: 40rpx;
  width: 100%;
  background: rgba(244,67,54,0.1);
  color: #F44336;
  border: 1rpx solid rgba(244,67,54,0.3);
  border-radius: var(--radius-md);
  padding: 22rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}

.reselect-btn {
  text-align: center;
  color: var(--primary-light);
  font-size: 24rpx;
  padding: 10rpx 0;
  margin-bottom: 20rpx;
}
