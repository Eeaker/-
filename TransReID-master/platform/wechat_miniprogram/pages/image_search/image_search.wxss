.image-search-container {
  padding-bottom: 50rpx;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.upload-box {
  width: 100%;
  height: 400rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-md);
  background: rgba(0,0,0,0.2);
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--text-secondary);
}

.upload-icon {
  font-size: 80rpx;
  font-weight: 300;
  margin-bottom: 10rpx;
}

.preview-img {
  max-width: 100%;
  max-height: 100%;
  display: block;
  object-fit: contain;
}

.reselect-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.6);
  color: #fff;
  text-align: center;
  font-size: 24rpx;
  padding: 12rpx 0;
}

.params-box {
  margin-top: 30rpx;
}

.param-row {
  margin-bottom: 30rpx;
}

.label {
  font-size: 26rpx;
  color: var(--text-main);
  display: block;
  margin-bottom: 10rpx;
}

/* Waterfall Grid */
.waterfall {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 20rpx;
  margin-top: 20rpx;
}

.result-item {
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: #23262F;
}

.result-img {
  width: 100%;
  height: 360rpx;
  display: block;
}

.score-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: rgba(0, 0, 0, 0.7);
  color: var(--primary-light);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  border: 1px solid var(--primary-color);
  backdrop-filter: blur(4px);
}
